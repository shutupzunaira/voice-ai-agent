# Network & Firewall Configuration for TalkScout
# Place in project root as .network.config

# ============================================
# FIREWALL SETTINGS
# ============================================

# macOS Firewall Status
# Value: 0 = Firewall disabled, 1 = Firewall enabled, 2 = Firewall enabled + stealth mode
FIREWALL_MODE=0

# Allow connections from localhost (always allowed for development)
ALLOW_LOCALHOST=true

# Allow IPv6 connections
ALLOW_IPV6=true

# ============================================
# SERVER CONFIGURATION
# ============================================

# Backend Server Settings
BACKEND_HOST=localhost
BACKEND_PORT=3001
BACKEND_PROTOCOL=http

# Frontend Server Settings  
FRONTEND_HOST=localhost
FRONTEND_PORT=5175
FRONTEND_PROTOCOL=http

# ============================================
# NETWORK SETTINGS
# ============================================

# Enable CORS (Cross-Origin Resource Sharing)
CORS_ENABLED=true

# Allowed origins for CORS
CORS_ORIGINS=http://localhost:5175,http://localhost:5174,http://localhost:5176,http://localhost:5177,http://127.0.0.1:5175

# Enable proxy for development
PROXY_ENABLED=true

# Proxy configuration
PROXY_TARGET=http://localhost:3001

# ============================================
# SECURITY SETTINGS
# ============================================

# Node environment
NODE_ENV=development

# Trust proxy (important for behind firewall/reverse proxy)
TRUST_PROXY=true

# Request size limits
REQUEST_SIZE_LIMIT=50mb

# File upload limits
UPLOAD_MAX_SIZE=25mb

# ============================================
# API ENDPOINTS
# ============================================

# Backend API URL (for frontend)
REACT_APP_API_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001

# Enable API logging
API_LOGGING=true

# ============================================
# HOSTNAME RESOLUTION
# ============================================

# Primary host
HOST=localhost

# Alternative hostnames
ALT_HOSTS=127.0.0.1,::1

# DNS settings
ENABLE_DNS_CACHE=true

# ============================================
# CONNECTION POOLING
# ============================================

# Keep-alive settings
KEEP_ALIVE=true
KEEP_ALIVE_TIMEOUT=65000

# Connection pool size
POOL_SIZE=10

# ============================================
# TIMEOUT SETTINGS
# ============================================

# Request timeout (ms)
REQUEST_TIMEOUT=30000

# Socket timeout (ms)
SOCKET_TIMEOUT=30000

# Keep-alive timeout (ms)
KEEP_ALIVE_TIMEOUT=65000
