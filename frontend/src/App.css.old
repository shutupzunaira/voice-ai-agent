/* Reset and base styles */
* {
  box-sizing: border-box;
}

html, body, #root {
  margin: 0;
  padding: 0;
  height: 100%;
  width: 100%;
}

.app-container {
  width: 100%;
  min-height: 100vh;
  font-family: "Poppins", sans-serif;
}

/* Page background */
.app-wrapper {
  min-height: 100vh;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(180deg, #ffffff 0%, #f5f5f5 100%);
  font-family: "Poppins", sans-serif;
  padding: 1rem;
}

/* Main container - no max-width, expands to fit */
.container {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
  background: white;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
}

/* Left panel */
.left-panel {
  flex: 1 1 280px;
  background: linear-gradient(135deg, #b6a6ff, #8e9bff);
  color: white;
  padding: 2rem;
  min-width: 0;
}

.left-panel h1 {
  margin: 0 0 0.5rem 0;
  font-size: clamp(1.5rem, 5vw, 2rem);
  word-break: break-word;
}

.left-panel p {
  margin: 0.5rem 0;
  font-size: clamp(0.9rem, 2vw, 1rem);
  word-break: break-word;
}

/* Right panel */
.right-panel {
  flex: 2 1 320px;
  padding: 2rem;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.right-panel h2 {
  margin: 0 0 1rem 0;
  color: #444;
  font-size: clamp(1.25rem, 4vw, 1.5rem);
}

/* Chat area */
.chat-box {
  flex: 1;
  background: #fafaff;
  border-radius: 12px;
  padding: 1.25rem;
  overflow-y: auto;
  min-height: 250px;
  color: #333;
  margin-bottom: 1rem;
  word-break: break-word;
}

/* Chat messages */
.message {
  margin-bottom: 0.875rem;
  line-height: 1.6;
  font-size: clamp(0.9rem, 1.5vw, 1rem);
}

/* Thinking text */
.loading {
  color: #777;
  font-style: italic;
}

/* Button section */
.button-group {
  margin-bottom: 1rem;
}

.ask-button {
  padding: 0.75rem 1rem;
  border-radius: 12px;
  border: none;
  background: #7b6ef6;
  color: white;
  font-size: clamp(0.9rem, 2vw, 1rem);
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.3s ease;
}

.ask-button:hover {
  background: #6a5fd1;
}

.ask-button.recording {
  background: #ff4757;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.7;
  }
}

/* Input section */
.input-group {
  display: flex;
  gap: 0.75rem;
  margin-top: 0;
}

.input-group input {
  flex: 1;
  min-width: 0;
  padding: 0.75rem;
  border-radius: 8px;
  border: 1px solid #ccc;
  font-size: clamp(0.9rem, 1.5vw, 1rem);
  font-family: "Poppins", sans-serif;
}

.input-group button {
  padding: 0.75rem 1rem;
  border-radius: 8px;
  border: none;
  background: #7b6ef6;
  color: white;
  cursor: pointer;
  font-size: clamp(0.9rem, 1.5vw, 1rem);
  white-space: nowrap;
  transition: background 0.3s ease;
}

.input-group button:hover {
  background: #6a5fd1;
}

/* Responsive adjustments for tablets and phones */
@media (max-width: 768px) {
  .app-wrapper {
    padding: 0.75rem;
  }

  .container {
    flex-direction: column;
  }

  .left-panel,
  .right-panel {
    flex: 1 1 auto;
  }

  .left-panel,
  .right-panel {
    padding: 1.5rem;
  }

  .ask-button {
    width: 100%;
  }
}

/* Extra small phones */
@media (max-width: 480px) {
  .app-wrapper {
    padding: 0.5rem;
  }

  .left-panel,
  .right-panel {
    padding: 1rem;
  }

  .input-group {
    flex-direction: column;
  }

  .input-group input,
  .input-group button {
    width: 100%;
  }

  .ask-button {
    width: 100%;
  }
}
